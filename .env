###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_random_32_char_string
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
